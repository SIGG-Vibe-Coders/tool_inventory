{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SIGG Tool Inventory",
  "description": "Schema for the SIGG tool inventory data file (data/tools.json).",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "name",
      "description",
      "location",
      "contact",
      "userGroup",
      "status",
      "lastUpdated"
    ],
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique slug, lowercase with hyphens (e.g. 'riparian-buffer-tool').",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "name": {
        "type": "string",
        "description": "Display name of the tool.",
        "minLength": 1
      },
      "description": {
        "type": "string",
        "description": "What the tool does.",
        "minLength": 1
      },
      "location": {
        "type": "string",
        "description": "Where the tool lives: a network path or a repository/URL link.",
        "minLength": 1
      },
      "howTo": {
        "type": "string",
        "description": "Optional link to instructions / how-to-use documentation."
      },
      "contact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "description": "Owner / who to contact if something goes wrong.",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "email": { "type": "string" }
        }
      },
      "userGroup": {
        "type": "string",
        "description": "Intended audience / user group for the tool.",
        "minLength": 1
      },
      "version": {
        "type": "string",
        "description": "Optional version label."
      },
      "lastUpdated": {
        "type": "string",
        "description": "Date the entry was last updated (YYYY-MM-DD).",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "status": {
        "type": "string",
        "description": "Lifecycle status of the tool.",
        "enum": ["active", "deprecated", "in-development"]
      },
      "tags": {
        "type": "array",
        "description": "Keywords for search and filtering.",
        "items": { "type": "string" }
      },
      "links": {
        "type": "array",
        "description": "Zero or more related links (videos, docs, etc.).",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "url"],
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "url": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
